# \uc0\u26680 \u24515 \u21312 \u22495 \u65306 \u19978 \u22478 \u21312 \u12300 \u32854 \u26684 \u29790 \u26031 \u12301 \u65288 St. Gries\u65289 \
- \uc0\u36889 \u35041 \u26159 \u22478 \u24066 \u30340 \u27402 \u21147 \u20013 \u27166 \u65292 \u34903 \u36947 \u26126 \u20142 \u25972 \u28500 \u65292 \u31354 \u20013 \u36556 \u36947 \u20132 \u37679 \u12290 \u12300 \u29983 \u29289 \u24615 \u23041 \u33029 \u31649 \u29702 \u32626  (BTMA) \u32317 \u37096 \u12301 \u20415 \u22352 \u33853 \u26044 \u27492 \u65292 \u37027 \u26159 \u19968 \u26847 \u22806 \u34920 \u20840 \u40657 \u12289 \u27794 \u26377 \u31383 \u25142 \u30340 \u24190 \u20309 \u24314 \u31689 \u65292 \u35937 \u24501 \u33879 \u32085 \u23565 \u30340 \u23553 \u38281 \u33287 \u23041 \u27402 \u12290 \u32202 \u37168 \u32317 \u37096 \u30340 \u26159 \u12300 \u20013 \u22830 \u22522 \u22240 \u30740 \u31350 \u37291 \u38498 \u12301 \u65292 \u23565 \u22806 \u26159 \u38914 \u23574 \u37291 \u30274 \u27231 \u27083 \u65292 \u23526 \u21063 \u22320 \u19979 \u20116 \u23652 \u30342 \u28858 \u26041 \u38748 \u20027 \u23566 \u30340 \u23526 \u39511 \u23460 \u12290 \u27492 \u21312 \u20296 \u28415 \u20102 \u12300 \u29983 \u29289 \u36027 \u27931 \u33945 \u25475 \u25551 \u20736 \u12301 \u65292 \u20219 \u20309 \u20405 \u34645 \u20540 \u36942 \u39640 \u30340 \u20491 \u39636 \u36914 \u20837 \u27492 \u21312 \u65292 \u37117 \u26371 \u31435 \u21051 \u35320 \u30332 \u35686 \u22577 \u65292 \u22240 \u27492 \u26159 \u31532 \u20108 \u30456 \u39636 \u30340 \u32085 \u23565 \u31105 \u21312 \u12290 \
