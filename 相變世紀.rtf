# \uc0\u29983 \u27963 \u21312 \u22495 \u65306 \u20013 \u22478 \u21312 \u12300 \u37002 \u30028 \u36208 \u24266 \u12301 \u65288 The Corridors\u65289 \
- \uc0\u19968 \u33324 \u24066 \u27665 \u23621 \u20303 \u30340 \u21312 \u22495 \u65292 \u20805 \u28415 \u20102 \u20844 \u23507 \u22823 \u27155 \u12289 \u21830 \u22580 \u33287 \u23416 \u26657 \u12290 \u36889 \u35041 \u30475 \u20284 \u24179 \u21644 \u65292 \u23526 \u21063 \u26263 \u27969 \u28263 \u21205 \u12290 **\u12300 \u32020 \u31278 \u23432 \u26395 \u25945 \u27966 \u12301 \u30340 \u23459 \u25945 \u20013 \u24515 \u24120 \u39376 \u26044 \u21508 \u20491 \u34903 \u35282 \u65292 \u30475 \u26495 \u19978 \u25773 \u25918 \u33879 \u12300 \u20445 \u35703 \u22522 \u22240 \u32020 \u28500 \u12301 \u30340 \u24291 \u21578 \u12290 \u12300 \u38520 \u29723 \u20219 \u32887 \u30340 \u24066 \u31435 \u24613 \u35386 \u20013 \u24515 \u12301 **\u20063 \u20301 \u26044 \u27492 \u34389 \u65292 \u36889 \u24231 \u37291 \u38498 \u26159 \u20013 \u22478 \u21312 \u26368 \u32321 \u24537 \u30340 \u22320 \u26041 \u65292 \u20063 \u26159 \u38520 \u29723 \u21033 \u29992 \u32887 \u21209 \u20043 \u20415 \u65292 \u31192 \u23494 \u28858 \u35258 \u37266 \u23569 \u24180 \u35386 \u26039 \u33287 \u34255 \u21311 \u25233 \u21046 \u21137 \u30340 \u25818 \u40670 \u12290 \u36889 \u35041 \u30340 \u30435 \u28204 \u36611 \u28858 \u39686 \u25955 \u65292 \u26159 \u22810 \u25976 \u31532 \u20108 \u30456 \u39636 \u20605 \u35037 \u25104 \u24120 \u20154 \u29983 \u27963 \u30340 \u22320 \u26041 \u12290 \
