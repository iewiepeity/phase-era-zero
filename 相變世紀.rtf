# \uc0\u20013 \u31435 \u22320 \u24118 \u65306 \u28784 \u33394 \u36991 \u38627 \u25152  (Gray Sanctuary)\
- \uc0\u36889 \u20006 \u38750 \u19968 \u20491 \u22196 \u23494 \u30340 \u32068 \u32340 \u65292 \u32780 \u26159 \u30001 \u38520 \u29723 \u12289 \u29791 \u23068 \u31561 \u23569 \u25976 \u20445 \u25345 \u29702 \u26234 \u30340  I \u22411 \u20491 \u39636 \u31192 \u23494 \u32232 \u32340 \u32780 \u25104 \u30340 \u20114 \u21161 \u32178 \u32097 \u12290 \u20182 \u20497 \u26082 \u19981 \u35469 \u21516 \u35299 \u25918 \u32068 \u32340 \u30340 \u26292 \u21147 \u65292 \u20063 \u24656 \u25084 \u25919 \u24220 \u30340 \u35299 \u21078 \u20992 \u12290 \u36889 \u32676 \u20154 \u21033 \u29992 \u33258 \u24049 \u30340 \u23560 \u26989 \u36523 \u20998 \u65288 \u22914 \u37291 \u29983 \u12289 \u37202 \u20445 \u12289 \u39405 \u23458 \u65289 \u28858 \u21463 \u38627 \u32773 \u25552 \u20379 \u38750 \u27861 \u25233 \u21046 \u21137 \u12289 \u20605 \u36896 \u36523 \u20998 \u35657 \u26126 \u65292 \u25110 \u25351 \u24341 \u20182 \u20497 \u36530 \u36991 \u29557 \u25429 \u37096 \u38538 \u30340 \u25628 \u25429 \u12290 \u20182 \u20497 \u30340 \u30446 \u27161 \u26997 \u20854 \u31777 \u21934 \u19988 \u21329 \u24494 \u65306 \u22312 \u19981 \u24341 \u36215 \u20219 \u20309 \u27874 \u28734 \u30340 \u24773 \u27841 \u19979 \u65292 \u20605 \u35037 \u25104 \u19968 \u20491 \u26222 \u36890 \u20154 \u65292 \u30452 \u21040 \u32769 \u27515 \u26044 \u36889 \u20491 \u20805 \u28415 \u25973 \u24847 \u30340 \u19990 \u30028 \u20013 \u12290 \
\uc0\u36889 \u24231 \u22478 \u24066 \u34987 \u31281 \u28858 \u12300 \u36093 \u24503 \u37324 \u26031 \u12301 \u65288 Cydris\u65289 \u65292 \u19968 \u24231 \u22312 \u32321 \u33775 \u38675 \u34425 \u33287 \u37628 \u37941 \u26862 \u26519 \u25513 \u33995 \u19979 \u65292 \u34389 \u34389 \u20805 \u28415 \u30435 \u25511 \u33287 \u38512 \u24433 \u30340 \u29694 \u20195 \u21270 \u28207 \u21475 \u37117 \u24066 \u12290 \u22320 \u22294 \u21576 \u29694 \u29872 \u29376 \u32080 \u27083 \u65292 \u30001 \u20839 \u32780 \u22806 \u35937 \u24501 \u33879 \u27402 \u21147 \u33287 \u29983 \u23384 \u31354 \u38291 \u30340 \u21085 \u38626 \u65306 \
