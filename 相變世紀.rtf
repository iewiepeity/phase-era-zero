# \uc0\u25919 \u24220 \u27231 \u27083 \u65306 \u29983 \u29289 \u24615 \u23041 \u33029 \u31649 \u29702 \u32626  (BTMA)\
\uc0\u30452 \u23660 \u26044 \u26368 \u39640 \u34892 \u25919 \u27231 \u38364 \u30340 \u31192 \u23494 \u27231 \u27083 \u65292 \u19979 \u35373 \u20841 \u22823 \u26680 \u24515 \u37096 \u38272 \u12290 \u12300 \u29305 \u27530 \u29557 \u25429 \u37096 \u38538  (STF)\u12301 \u36000 \u36012 \u22478 \u24066 \u30340 \u26085 \u24120 \u30435 \u28204 \u33287 \u12300 \u39640 \u21361 \u20491 \u39636 \u12301 \u30340 \u22238 \u25910 \u65292 \u38538 \u21729 \u22823 \u22810 \u30001 \u21463 \u36942 \u21453 \u29560 \u21270 \u25136 \u34899 \u35347 \u32244 \u30340 \u36557 \u20107 \u31934 \u33521 \u32068 \u25104 \u65292 \u38568 \u36523 \u37197 \u20633 \u39640 \u22739 \u38651 \u25802 \u27085 \u12289 \u38899 \u27874 \u37806 \u38748 \u24392 \u33287 \u33021 \u36861 \u36452 \u29305 \u23450 \u36027 \u27931 \u33945 \u30340 \u29983 \u29289 \u38647 \u36948 \u65307 \u12300 \u29983 \u29289 \u30740 \u31350 \u20013 \u24515  (BRC)\u12301 \u21063 \u30001 \u26041 \u38748 \u31561 \u31185 \u23416 \u23478 \u20027 \u23566 \u65292 \u33268 \u21147 \u26044 \u30772 \u35299 \u31532 \u20108 \u30456 \u39636 \u30340 \u22522 \u22240 \u23494 \u30908 \u12290 \u20182 \u20497 \u23559 \u25910 \u23481 \u32773 \u32232 \u34399 \u20006 \u22234 \u31105 \u26044 \u21517 \u28858 \u12300 \u30703 \u27491 \u20013 \u24515 \u12301 \u30340 \u22320 \u19979 \u35373 \u26045 \u65292 \u34920 \u38754 \u19978 \u23459 \u31281 \u26159 \u28858 \u20102 \u38283 \u30332 \u31337 \u23450 \u24773 \u32210 \u30340 \u25233 \u21046 \u21137 \u65292 \u23526 \u21063 \u36914 \u34892 \u27544 \u37239 \u30340 \u29983 \u29289 \u20853 \u22120 \u23526 \u39511 \u65292 \u35430 \u22294 \u20154 \u24037 \u35480 \u30332 \u20986 \u26356 \u20855 \u25136 \u39717 \u24615 \u30340 \u35722 \u30064 \u30456 \u24907 \u12290 \u23565 \u20182 \u20497 \u32780 \u35328 \u65292 \u31532 \u20108 \u30456 \u39636 \u19981 \u26159 \u20154 \u39006 \u65292 \u32780 \u26159 \u24453 \u25286 \u35299 \u30340 \u29983 \u29289 \u25976 \u25818 \
# \uc0\u27665 \u38291 \u32068 \u32340 \u65306 \u31532 \u20108 \u30456 \u39636 \u35299 \u25918 \u32068 \u32340  (SPRO)\
\uc0\u30001 \u33673 \u33673 \u32114 \u31561 \u28608 \u36914 \u27966 \u38936 \u23566 \u30340 \u22320 \u19979 \u32068 \u32340 \u65292 \u25104 \u21729 \u21253 \u21547 \u24050 \u35258 \u37266 \u30340 \u31532 \u20108 \u30456 \u39636 \u21450 \u20854 \u29378 \u29105 \u25903 \u25345 \u32773 \u12290 \u20449 \u22857 \u12300 \u36914 \u21270 \u35542 \u12301 \u65292 \u20027 \u24373 \u29560 \u21270 \u26159 \u20154 \u39006 \u31361 \u30772 \u22522 \u22240 \u26551 \u37782 \u12289 \u22238 \u27512 \u33258 \u28982 \u30340 \u24517 \u32147 \u20043 \u36335 \u65292 \u35469 \u28858 \u20154 \u39006 \u25919 \u24220 \u30340 \u22739 \u36843 \u26159 \u33853 \u24460 \u29289 \u31278 \u23565 \u20808 \u36914 \u29289 \u31278 \u30340 \u23241 \u22930 \u12290 \u35442 \u32068 \u32340 \u22312 \u26263 \u32178 \u36939 \u34892 \u65292 \u23560 \u38272 \u31574 \u21123 \u35186 \u25802 \u25910 \u23481 \u20013 \u24515 \u12289 \u26263 \u27578 \u29557 \u25429 \u38538 \u25104 \u21729 \u65292 \u20006 \u21521 \u23578 \u26410 \u35258 \u37266 \u30340 \u38738 \u23569 \u24180 \u25955 \u20296 \u12300 \u35258 \u37266 \u26159 \u27054 \u35709 \u12301 \u30340 \u27927 \u33126 \u24605 \u24819 \u12290 \u20182 \u20497 \u29978 \u33267 \u26371 \u20379 \u39178 \u20687 \u12300 \u22823 \u29066 \u12301 \u36889 \u27171 \u23436 \u20840 \u22833 \u25511 \u30340  III \u22411 \u20491 \u39636 \u65292 \u23559 \u20854 \u35222 \u28858 \u32854 \u20687 \u25110 \u22312 \u25136 \u39717 \u26178 \u25237 \u25918 \u30340 \u29983 \u29289 \u20853 \u22120 \u65292 \u25163 \u27573 \u27544 \u26292 \u19988 \u26997 \u20855 \u29053 \u21205 \u21147 \
# \uc0\u23447 \u25945 \u22296 \u39636 \u65306 \u32020 \u31278 \u23432 \u26395 \u25945 \u27966 \
\uc0\u36889 \u26159 \u19968 \u20491 \u30001 \u26997 \u31471 \u20154 \u39006 \u20027 \u32681 \u32773 \u32068 \u25104 \u30340 \u19990 \u20439 \u25945 \u27966 \u65292 \u20449 \u24466 \u22810 \u28858 \u22312 \u29560 \u21270 \u20107 \u20214 \u20013 \u36973 \u21463 \u25613 \u22833 \u30340 \u24179 \u27665 \u25110 \u23565 \u26410 \u30693 \u29983 \u29289 \u24863 \u21040 \u24656 \u25084 \u30340 \u31038 \u26371 \u20013 \u23652 \u12290 \u20182 \u20497 \u23815 \u23578 \u12300 \u22522 \u22240 \u31070 \u32854 \u19981 \u21487 \u20405 \u29359 \u12301 \u65292 \u35469 \u28858 \u31532 \u20108 \u30456 \u39636 \u26159 \u34987 \u24801 \u39764 \u25110 \u36667 \u23556 \u27737 \u26579 \u30340 \u30072 \u24418 \u29986 \u29289 \u65292 \u26371 \u25943 \u22750 \u20154 \u39006 \u31038 \u26371 \u30340 \u32020 \u28500 \u12290 \u25945 \u27966 \u22312 \u27665 \u38291 \u24314 \u31435 \u20102 \u22196 \u23494 \u30340 \u12300 \u37168 \u37324 \u30435 \u35222 \u32178 \u12301 \u65292 \u40723 \u21237 \u27665 \u30526 \u33289 \u22577 \u20219 \u20309 \u34892 \u28858 \u24618 \u30064 \u30340 \u37168 \u23621 \u65292 \u22914 \u39135 \u37327 \u26292 \u22686 \u12289 \u24773 \u32210 \u22833 \u25511 \u25110 \u36530 \u36991 \u20809 \u32218 \u31561 \u24501 \u20806 \u12290 \u20182 \u20497 \u19981 \u30452 \u25509 \u21443 \u33287 \u25136 \u39717 \u65292 \u21371 \u36879 \u36942 \u36671 \u35542 \u29053 \u21205 \u22823 \u30526 \u23565 \u29560 \u21270 \u32773 \u30340 \u25490 \u25824 \u33287 \u24656 \u25084 \u65292 \u26159 \u25919 \u24220 \u25512 \u34892 \u39640 \u22739 \u25919 \u31574 \u30340 \u26368 \u24375 \u27665 \u24847 \u24460 \u30462 \u12290 \
# \uc0\u20013 \u31435 \u22320 \u24118 \u65306 \u28784 \u33394 \u36991 \u38627 \u25152  (Gray Sanctuary)\
\uc0\u36889 \u20006 \u38750 \u19968 \u20491 \u22196 \u23494 \u30340 \u32068 \u32340 \u65292 \u32780 \u26159 \u30001 \u38520 \u29723 \u12289 \u29791 \u23068 \u31561 \u23569 \u25976 \u20445 \u25345 \u29702 \u26234 \u30340  I \u22411 \u20491 \u39636 \u31192 \u23494 \u32232 \u32340 \u32780 \u25104 \u30340 \u20114 \u21161 \u32178 \u32097 \u12290 \u20182 \u20497 \u26082 \u19981 \u35469 \u21516 \u35299 \u25918 \u32068 \u32340 \u30340 \u26292 \u21147 \u65292 \u20063 \u24656 \u25084 \u25919 \u24220 \u30340 \u35299 \u21078 \u20992 \u12290 \u36889 \u32676 \u20154 \u21033 \u29992 \u33258 \u24049 \u30340 \u23560 \u26989 \u36523 \u20998 \u65288 \u22914 \u37291 \u29983 \u12289 \u37202 \u20445 \u12289 \u39405 \u23458 \u65289 \u28858 \u21463 \u38627 \u32773 \u25552 \u20379 \u38750 \u27861 \u25233 \u21046 \u21137 \u12289 \u20605 \u36896 \u36523 \u20998 \u35657 \u26126 \u65292 \u25110 \u25351 \u24341 \u20182 \u20497 \u36530 \u36991 \u29557 \u25429 \u37096 \u38538 \u30340 \u25628 \u25429 \u12290 \u20182 \u20497 \u30340 \u30446 \u27161 \u26997 \u20854 \u31777 \u21934 \u19988 \u21329 \u24494 \u65306 \u22312 \u19981 \u24341 \u36215 \u20219 \u20309 \u27874 \u28734 \u30340 \u24773 \u27841 \u19979 \u65292 \u20605 \u35037 \u25104 \u19968 \u20491 \u26222 \u36890 \u20154 \u65292 \u30452 \u21040 \u32769 \u27515 \u26044 \u36889 \u20491 \u20805 \u28415 \u25973 \u24847 \u30340 \u19990 \u30028 \u20013 \
