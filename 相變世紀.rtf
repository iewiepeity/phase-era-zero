# \uc0\u23447 \u25945 \u22296 \u39636 \u65306 \u32020 \u31278 \u23432 \u26395 \u25945 \u27966  (Pure-Blood Watchers)\
- \uc0\u36889 \u26159 \u19968 \u20491 \u30001 \u26997 \u31471 \u20154 \u39006 \u20027 \u32681 \u32773 \u32068 \u25104 \u30340 \u19990 \u20439 \u25945 \u27966 \u65292 \u20449 \u24466 \u22810 \u28858 \u22312 \u29560 \u21270 \u20107 \u20214 \u20013 \u36973 \u21463 \u25613 \u22833 \u30340 \u24179 \u27665 \u25110 \u23565 \u26410 \u30693 \u29983 \u29289 \u24863 \u21040 \u24656 \u25084 \u30340 \u31038 \u26371 \u20013 \u23652 \u12290 \u20182 \u20497 \u23815 \u23578 \u12300 \u22522 \u22240 \u31070 \u32854 \u19981 \u21487 \u20405 \u29359 \u12301 \u65292 \u35469 \u28858 \u31532 \u20108 \u30456 \u39636 \u26159 \u34987 \u24801 \u39764 \u25110 \u36667 \u23556 \u27737 \u26579 \u30340 \u30072 \u24418 \u29986 \u29289 \u65292 \u26371 \u25943 \u22750 \u20154 \u39006 \u31038 \u26371 \u30340 \u32020 \u28500 \u12290 \u25945 \u27966 \u22312 \u27665 \u38291 \u24314 \u31435 \u20102 \u22196 \u23494 \u30340 \u12300 \u37168 \u37324 \u30435 \u35222 \u32178 \u12301 \u65292 \u40723 \u21237 \u27665 \u30526 \u33289 \u22577 \u20219 \u20309 \u34892 \u28858 \u24618 \u30064 \u30340 \u37168 \u23621 \u65292 \u22914 \u39135 \u37327 \u26292 \u22686 \u12289 \u24773 \u32210 \u22833 \u25511 \u25110 \u36530 \u36991 \u20809 \u32218 \u31561 \u24501 \u20806 \u12290 \u20182 \u20497 \u19981 \u30452 \u25509 \u21443 \u33287 \u25136 \u39717 \u65292 \u21371 \u36879 \u36942 \u36671 \u35542 \u29053 \u21205 \u22823 \u30526 \u23565 \u29560 \u21270 \u32773 \u30340 \u25490 \u25824 \u33287 \u24656 \u25084 \u65292 \u26159 \u25919 \u24220 \u25512 \u34892 \u39640 \u22739 \u25919 \u31574 \u30340 \u26368 \u24375 \u27665 \u24847 \u24460 \u30462 \u12290 \
